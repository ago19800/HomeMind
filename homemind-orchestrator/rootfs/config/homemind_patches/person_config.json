{
  "_info": "File di configurazione HomeMind — modifica questo file e riavvia l'addon.",
  "_info2": "I campi con _comment sono solo spiegazioni, non vengono letti dal codice.",
  "_info3": "Per trovare i tuoi entity_id: HA → Strumenti Sviluppo → Stati",

  "person_whitelist": [
    "person.agostino",
    "person.rosa"
  ],

  "person_blacklist": [
    "person.mqtt"
  ],

  "motion_whitelist": [
    "binary_sensor.0x00158d000224fb57_occupancy",
    "binary_sensor.0x00158d0001ae9a1b_occupancy",
    "binary_sensor.0x000d6ffffe1a246d_occupancy",
    "binary_sensor.0x00158d000224fa71_occupancy"
  ],

  "motion_blacklist": [
    "binary_sensor.cast",
    "binary_sensor.lc_motion_alarm",
    "binary_sensor.presenza_moving_target_2",
    "binary_sensor.test_sensore_presenza"
  ],

  "contact_blacklist": [
    "binary_sensor.allarme_sensore_porta_porta",
    "binary_sensor.contact_sensor_porta"
  ],

  "temperature_sensors": [
    "sensor.temperature_158d00022c9399",
    "sensor.temperature_158d00022caebe",
    "sensor.2o_echo_dot_di_russo_temperature"
  ],

  "energy_sensors": {
    "consumo_casa": "sensor.daily_energy_combined",
    "rete_enel":    "sensor.enel"
  },

  "_section_fascia": "──────────── CONSUMI PER FASCIA ORARIA ────────────",
  "_fascia_info": "Sensori utility_meter con tariffe F1/F2/F3 presenti nel tuo HA.",
  "_fascia_info2": "Verifica i nomi esatti: HA → Strumenti Sviluppo → Stati → cerca energia_oggi",

  "fascia_sensors": {
    "oggi_f1":      "sensor.energia_oggi_f1_f1",
    "oggi_f2":      "sensor.energia_oggi_f1_f2",
    "oggi_f3":      "sensor.energia_oggi_f1_f3",
    "oggi_tot":     "sensor.energia_oggi_totale",
    "mese_f1":      "sensor.energia_mese_f1_f1",
    "mese_f2":      "sensor.energia_mese_f1_f2",
    "mese_f3":      "sensor.energia_mese_f1_f3",
    "mese_tot":     "sensor.energia_mese_totale",
    "daily_source": "sensor.enel"
  },

  "spazzatura_notify_enabled": true,
  "spazzatura_notify_hour": 15,

  "frigate": {
    "enabled": true,
    "host": "192.168.1.119",
    "port": 5000,
    "snapshot_on_alarm": true,
    "cameras": {
      "cucina":    "binary_sensor.0x00158d000224fb57_occupancy",
      "primpiano": "binary_sensor.0x000d6ffffe1a246d_occupancy"
    }
  },

  "proximity_sensors": {
    "person.agostino": {
      "sensor":        "sensor.casa_sm_s931b_distance",
      "threshold_m":   100,
      "stale_check":   false,
      "stale_minutes": 10
    }
  },

  "alarm_panel": "alarm_control_panel.nome_del_tuo_risco",

  "climate": {
    "climate.termostato": {
      "name":     "Termostato casa",
      "switch":   "switch.tasmota",
      "min_temp": 15,
      "max_temp": 30
    }
  },

  "appliances": {
    "lavastoviglie": {
      "enabled": true,
      "name": "Lavastoviglie",
      "icon": "🍽️",
      "mode": "smart",
      "state_sensor": "sensor.homeconnect_status",
      "running_states": ["Run"],
      "done_states": ["Finished", "Ready"],
      "program_sensor": "sensor.lavastoviglie_selected_program",
      "door_sensor": "binary_sensor.lavastoviglie_door",
      "notify_on_start": false
    },
    "lavatrice": {
      "enabled": true,
      "name": "Lavatrice",
      "icon": "🫧",
      "mode": "power",
      "power_sensor": "sensor.0x6cfd22fffe1a1494_power",
      "power_on_threshold": 50,
      "power_off_threshold": 10,
      "min_cycle_minutes": 20,
      "max_idle_minutes": 5,
      "notify_on_start": false
    },
    "asciugatrice": {
      "enabled": false,
      "name": "Asciugatrice",
      "icon": "🌀",
      "mode": "power",
      "power_sensor": "sensor.SOSTITUISCI_asciugatrice_power",
      "power_on_threshold": 100,
      "power_off_threshold": 15,
      "min_cycle_minutes": 25,
      "max_idle_minutes": 8,
      "notify_on_start": false
    },
    "forno": {
      "enabled": false,
      "name": "Forno",
      "icon": "🔥",
      "mode": "power",
      "power_sensor": "sensor.SOSTITUISCI_forno_power",
      "power_on_threshold": 500,
      "power_off_threshold": 30,
      "min_cycle_minutes": 10,
      "max_idle_minutes": 3,
      "notify_on_start": false
    }
  },

  "language": "it",
  "timezone": "Europe/Rome",

  "solar_optimizer": {
    "enabled": true,
    "min_surplus_w": 500,
    "confirm_minutes": 5,
    "cooldown_hours": 2,
    "appliances": {
      "lavatrice": {
        "enabled": true,
        "switch": "switch.0x6cfd22fffe1a1494",
        "min_surplus_w": 800,
        "auto_start": false
      },
      "lavastoviglie": {
        "enabled": false,
        "switch": null,
        "min_surplus_w": 500,
        "auto_start": false
      }
    },
    "battery_soc_sensor": "sensor.inverter_pipsolar_battery_capacity_percent",
    "battery_full_threshold": 95,
    "battery_full_min_fv_w": 300,
    "min_sun_elevation": 10
  },

  "location_tracker": {
    "agostino": "device_tracker.sm_s931b",
    "rosa":     "device_tracker.sm_a166b"
  },

  "power_guard": {
    "enabled": true,
    "threshold_w": 3000,
    "warning_pct": 90,
    "mode": "ask",
    "power_sensor": "sensor.shellyem_ec64c9c68991_channel_1_power",
    "appliances_priority": [
      {
        "name": "Lavatrice",
        "switch": "switch.0x6cfd22fffe1a1494"
      }
    ],
    "delay_minutes": 5
  },

  "custom_briefing": {
    "tip_mode": "sports",
    "exclude_sections": ["spazzatura", "meteo"],
    "custom_greeting": "Buongiorno Agostino! ☀️"
  },

  "quiet_hours": {
    "enabled": false,
    "start": 23,
    "end": 7
  },

  "ai_providers": [
    {
      "name": "gemini",
      "model": "gemini-3.1-flash-lite-preview",
      "api_key": "AIzaSyAZLBnfhxZv9EtUgprSwJSdm_1VZ0lIbKU"
    },
    {
      "name": "mistral",
      "model": "mistral-small-latest",
      "api_key": "kJNek3hoaRlryWhUR8ViSgrOPAiG8BjL"
    }
  ]
}
